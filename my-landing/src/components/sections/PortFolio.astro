---
// src/components/sections/Portfolio.astro
const optimizeCloudinary = (url, width) =>
  url.includes("/upload/")
    ? url.replace("/upload/", `/upload/f_auto,q_auto,w_${width},c_limit/`)
    : url;

// Datos de ejemplo para el portfolio
const projects = [
  {
    title: "Cheepers App",
    description: "Plataforma web y gestión de pedidos para un local de hamburguesas.",
    imgSrc: "https://res.cloudinary.com/dwqxdensk/image/upload/v1761365582/cheepers-ecommerce_odgkvu.jpg", 
    tech: ["React", "Typescript", "Node.js", "MongoDB"],
    url: "https://cheepersapp.vercel.app/"
  },
  {
    title: "Modeladopao App",
    description: "Plataforma E-commerce para negocio artesanal de porcelana fría.",
    imgSrc: "https://res.cloudinary.com/dwqxdensk/image/upload/v1761366347/modeladopaoe_ujfxq3.jpg",
    tech: ["React", "TypeScript", "Firebase", "Tailwind"],
    url: "https://modelado-pao.vercel.app/"
  },
  {
    title: "Kiszcka Repuestos Page",
    description: "Landing page para venta de repuestos de Mercedes Benz, con gestión de inventario y contacto directo.",
    imgSrc: "https://res.cloudinary.com/dwqxdensk/image/upload/v1782446067/2f8994e3-c89f-48ad-b94f-312a959195f3.png",
    tech: ["Nextjs", "TypeScript", "Tailwind"],
    url: "https://kiszcka-repuestos.vercel.app/#inicio"
  }
];
---

<section id="proyectos" class="py-16 sm:py-32" data-aos="fade-up">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10">
    <div class="max-w-3xl relative pl-6 sm:pl-10 text-left mb-12 sm:mb-16" data-aos="fade-up" data-aos-delay="100">
      <span class="absolute left-0 top-4 h-3 w-3 rounded-full border border-indigo-200/80 bg-slate-900"></span>
      <h2 class="font-mont text-3xl md:text-4xl font-semibold text-indigo-200">
        Nuestros Trabajos
      </h2>
      <p class="font-poppins text-neutral-300 text-lg md:text-xl mt-4">
        Soluciones reales para clientes reales.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project, index) => (
        <div class="group border border-white/10 rounded-2xl bg-black/20 overflow-hidden transition-colors transition-transform duration-300 hover:bg-black/40 hover:border-indigo-400/30 hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(129,140,248,0.12)]" data-aos="fade-up" data-aos-delay={index * 120}>
          
          <img 
            src={optimizeCloudinary(project.imgSrc, 660)}
            srcset={`${optimizeCloudinary(project.imgSrc, 400)} 400w, ${optimizeCloudinary(project.imgSrc, 530)} 530w, ${optimizeCloudinary(project.imgSrc, 660)} 660w`}
            sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw"
            alt={`Screenshot del proyecto ${project.title} - Desarrollo web AFdevelopers`} 
            class="w-full h-48 object-cover object-top transition-opacity transition-transform duration-500 group-hover:opacity-80 group-hover:scale-105" loading="lazy" decoding="async" width="440" height="264"
            referrerpolicy="no-referrer"
          />
          
          <div class="p-6">
            <h3 class="font-mont text-xl font-semibold mb-2 text-indigo-300 group-hover:text-cyan-300 transition-colors duration-300">{project.title}</h3>
            <p class="font-poppins text-neutral-200/80 text-sm leading-relaxed mb-4">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2 mb-6">
              {project.tech.map(techName => (
                <span class="bg-indigo-400/10 text-indigo-300 text-xs font-medium px-2.5 py-0.5 rounded-full border border-indigo-500/10 group-hover:bg-indigo-400/20 transition-colors duration-300">
                  {techName}
                </span>
              ))}
            </div>

            {project.url !== "#" ? (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-5 py-2 rounded-full border border-indigo-300/60 text-indigo-100 text-sm font-poppins hover:bg-gradient-to-r hover:from-indigo-400 hover:to-cyan-400 hover:text-slate-900 hover:border-transparent transition-colors duration-300"
              >
                Ver proyecto
              </a>
            ) : (
              <span
                class="inline-block px-5 py-2 rounded-full border border-indigo-300/30 text-indigo-100/60 text-sm font-poppins cursor-not-allowed"
                aria-disabled="true"
              >
                Próximamente
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
