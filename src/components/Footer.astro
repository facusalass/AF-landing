---
import { Icon } from "astro-icon/components";

const logoUrl = "https://res.cloudinary.com/dwqxdensk/image/upload/f_auto,q_auto,w_112,h_112,c_fit/v1782446017/aflogo_uzslpd.png";
const navLinks = [
  { label: "Inicio", href: "#inicio" },
  { label: "Qué hacemos", href: "#soluciones" },
  { label: "Proyectos", href: "#proyectos" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Reseñas", href: "#reseñas" },
  { label: "Contacto", href: "#contacto" },
];
---

<footer class="relative mt-1" data-aos="fade-up">
  <div class="h-px bg-gradient-to-r from-transparent via-indigo-400/50 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 py-8 sm:py-10">
    <div class="flex flex-col lg:flex-row items-center lg:items-start justify-between gap-6 lg:gap-10">

      <div class="flex flex-col items-center lg:items-start gap-3 shrink-0">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="Ir al inicio de AFdevelopers">
          <img
            src={logoUrl}
            alt="AFdevelopers logo"
            class="h-10 w-auto object-contain group-hover:scale-105 transition-transform duration-300"
            width="56"
            height="56"
            loading="lazy"
            decoding="async"
          />
          <span class="font-mont text-white text-lg tracking-tight">
            <span class="italic font-semibold">AF</span><span class="not-italic font-normal">developers</span>
          </span>
        </a>
      </div>

      <nav class="flex flex-wrap justify-center gap-x-5 gap-y-1.5 font-poppins text-sm text-neutral-400" aria-label="Navegación del footer">
        {navLinks.map((link) => (
          <a href={link.href} class="hover:text-cyan-300 transition-colors">
            {link.label}
          </a>
        ))}
      </nav>

      <form
        action="/api/subscribe"
        method="POST"
        class="flex items-stretch w-full lg:w-auto min-w-0 max-w-sm"
      >
        <input type="hidden" name="subject" value="Nueva suscripcion desde AFdevelopers" />
        <label for="footer-email" class="sr-only">Tu correo electrónico</label>
        <input
          id="footer-email"
          type="email"
          name="email"
          required
          placeholder="tu@email.com"
          autocomplete="email"
          class="w-full min-w-0 px-4 py-2 rounded-l-full bg-slate-800/80 text-sm text-neutral-200 outline-none font-poppins border border-white/10 border-r-0 focus:border-indigo-400/50 placeholder-neutral-500 transition-colors"
        />
        <button
          type="submit"
          class="shrink-0 px-4 py-2 rounded-r-full bg-gradient-to-r from-indigo-400 to-cyan-400 text-slate-900 font-poppins text-sm font-semibold hover:from-indigo-300 hover:to-cyan-300 transition-colors"
        >
          Enviar
        </button>
      </form>
    </div>

    <div class="mt-6 pt-5 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-poppins text-xs text-neutral-500">
        &copy; 2026 AFdevelopers
      </p>

      <div class="flex items-center gap-1">
        <a
          href="mailto:afdevelopers12@gmail.com"
          class="p-1.5 rounded-lg text-neutral-500 hover:text-cyan-300 hover:bg-indigo-500/10 hover:ring-1 hover:ring-indigo-400/30 transition-all duration-200"
          aria-label="Enviar correo a AFdevelopers"
        >
          <Icon name="heroicons:envelope" class="w-4 h-4" />
        </a>
        <a
          href="https://www.instagram.com/afdeveloperss/"
          target="_blank"
          rel="noopener noreferrer"
          class="p-1.5 rounded-lg text-neutral-500 hover:text-cyan-300 hover:bg-indigo-500/10 hover:ring-1 hover:ring-indigo-400/30 transition-all duration-200"
          aria-label="Ir al Instagram de AFdevelopers"
        >
          <Icon name="simple-icons:instagram" class="w-4 h-4" />
        </a>
        <a
          href="https://wa.me/3624250501"
          target="_blank"
          rel="noopener noreferrer"
          class="p-1.5 rounded-lg text-neutral-500 hover:text-cyan-300 hover:bg-indigo-500/10 hover:ring-1 hover:ring-indigo-400/30 transition-all duration-200"
          aria-label="Contactar por WhatsApp con AFdevelopers"
        >
          <Icon name="logos:whatsapp-icon" class="w-4 h-4" />
        </a>
      </div>

      <a
        href="#inicio"
        class="group inline-flex items-center gap-1 text-xs text-neutral-500 hover:text-cyan-300 transition-colors font-poppins"
        aria-label="Volver al inicio de la página"
      >
        Volver arriba
        <svg
          class="w-3 h-3 group-hover:-translate-y-0.5 transition-transform"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 19V5m-7 7l7-7 7 7" />
        </svg>
      </a>
    </div>
  </div>
</footer>
