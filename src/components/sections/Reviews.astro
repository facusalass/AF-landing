---
// src/components/sections/Review.astro
const optimizeCloudinary = (url, width) =>
  url.includes("/upload/")
    ? url.replace("/upload/", `/upload/f_auto,q_auto,w_${width},c_limit/`)
    : url;

// Datos de ejemplo para las reseñas
const reviews = [
  {
    quote: "Transformaron nuestra idea en una plataforma increíble. El proceso fue claro y el resultado superó nuestras expectativas. ¡100% recomendados!",
    author: "Ricardo Salas",
    title: "Dueño, Negocio Local",
    avatarUrl: "https://res.cloudinary.com/dwqxdensk/image/upload/v1777519536/246262460_308333777433759_9222129765407179785_n_nn8iuw.jpg" 
  },
  {
    quote: "Desde que implementamos el sistema a medida, ahorramos horas de trabajo manual cada semana. ¡Un antes y un después para nuestra gestión!",
    author: "Paola Ferrari",
    title: "Dueña de su emprendimiento",
    avatarUrl: "https://res.cloudinary.com/dech9w3wx/image/upload/v1777519851/608767837_18548098465019445_2618285411734250384_n_uz9ztv.jpg"
  },
  {
    quote: "Desde que tengo mi pagina puedo recepcionar mis pedidos con claridad y tener control de mis ventas",
    author: "Dylan Rojas",
    title: "Dueño, Negocio gastronomico",
    avatarUrl: "https://res.cloudinary.com/dwqxdensk/image/upload/v1774491741/image_so7u3x.png"
  }
];
---

<section id="reseñas" class="py-16 sm:py-32" data-aos="fade-up">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10">
    <div class="max-w-3xl relative pl-6 sm:pl-10 text-left mb-12 sm:mb-16" data-aos="fade-up" data-aos-delay="100">
      <span class="absolute left-0 top-4 h-3 w-3 rounded-full border border-indigo-200/80 bg-slate-900"></span>
      <h2 class="font-mont text-3xl md:text-4xl font-semibold text-indigo-200">
        Lo que dicen nuestros clientes
      </h2>
      <p class="font-poppins text-neutral-300 text-lg md:text-xl mt-4">
        Historias de éxito de negocios como el tuyo.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {reviews.map((review) => (
        <figure class="p-6 border border-white/10 rounded-2xl bg-black/20 flex flex-col transition-all duration-300 hover:border-white/20" data-aos="fade-up">
          {/* La Cita */}
          <blockquote class="text-neutral-200 flex-grow">
            <p class="font-poppins text-base leading-relaxed before:content-['“'] before:mr-1 after:content-['”'] after:ml-1">
              {review.quote}
            </p>
          </blockquote>
          
          {/* El Autor */}
          <figcaption class="mt-6 flex items-center gap-4 border-t border-white/10 pt-6">
            <img 
                src={optimizeCloudinary(review.avatarUrl, 128)} 
                srcset={`${optimizeCloudinary(review.avatarUrl, 64)} 64w, ${optimizeCloudinary(review.avatarUrl, 96)} 96w, ${optimizeCloudinary(review.avatarUrl, 128)} 128w`}
                sizes="48px"
                alt={`Avatar de ${review.author}`} 
                class="w-12 h-12 rounded-full object-cover flex-shrink-0 border border-white/10"
                loading="lazy"
                decoding="async"
                width="48"
                height="48"
            />
            <div>
              <div class="font-mont font-semibold text-indigo-300">{review.author}</div>
              <div class="text-neutral-400 text-sm font-poppins">{review.title}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
