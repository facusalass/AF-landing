---
import "../styles/global.css";
import "aos/dist/aos.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PainPoints from "../components/sections/PainPoints.astro";
import Portfolio from "../components/sections/PortFolio.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import ReviewSection from "../components/sections/Reviews.astro";
import BenefitsSection from "../components/sections/Benefits.astro";
import AboutVideo from "../components/sections/AboutVideo.astro";

const siteUrl = Astro.site ? new URL(Astro.site) : new URL("https://example.com");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImageUrl = new URL("/og-image.svg", siteUrl).toString();
const hasConfiguredSite = siteUrl.hostname !== "example.com";
const pageTitle = "AFdevelopers | Software a medida";
const pageDescription =
  "Creamos soluciones digitales personalizadas: sitios web, sistemas y plataformas que impulsan tu negocio.";
const robotsContent = hasConfiguredSite
  ? "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
  : "noindex, nofollow";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "AFdevelopers",
    url: siteUrl.toString(),
    logo: new URL("/favicon.svg", siteUrl).toString(),
    email: "afdevelopers12@gmail.com",
    sameAs: ["https://www.instagram.com/afdeveloperss/"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "AFdevelopers",
    url: siteUrl.toString(),
    inLanguage: "es-AR",
  },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="author" content="AFdevelopers" />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#020617" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AFdevelopers" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="AFdevelopers - Desarrollo de software a medida" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,600;1,600&family=Poppins:wght@400;500;600&display=swap"
    />
    <link rel="dns-prefetch" href="https://res.cloudinary.com" />
    <link rel="dns-prefetch" href="https://i.ytimg.com" />
    <link rel="dns-prefetch" href="https://www.youtube.com" />
    <link rel="dns-prefetch" href="https://calendly.com" />

    <title>{pageTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>

  <body class="min-h-screen text-white selection:bg-indigo-500/30">
    <div class="fixed inset-0 z-0 bg-slate-900">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(129,140,248,0.15),transparent)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_60%_at_100%_100%,rgba(34,211,238,0.1),transparent)]"></div>
    </div>

    <div class="relative z-10">
      <div class="py-8 sm:py-10">
        <Header rightInicio="Inicio" rightinfo="Trabajos" rightCta="Contactanos" ctaHref="#contacto" />
      </div>

      <main>
        <section id="inicio" class="py-16 sm:py-20" data-aos="fade-up">
          <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-10" data-aos="fade-up" data-aos-delay="100">
            <h1 class="font-mont font-semibold text-3xl sm:text-4xl md:text-6xl text-white text-left">
              Bienvenidos a <span class="italic font-bold text-neutral-200">AFdevelopers</span>
            </h1>

            <h2 class="font-mont text-xl sm:text-2xl md:text-4xl font-semibold mt-3 text-left text-slate-100 leading-snug">
              Transforma tu negocio en una plataforma <br class="hidden sm:block" /> Que vende, gestiona y crece sola.
            </h2>

            <p class="font-poppins text-sm sm:text-base md:text-xl text-neutral-200 mt-6 max-w-2xl leading-relaxed">
              Desarrollamos sitios web, sistemas y plataformas modernas que se adaptan totalmente a las necesidades de tu negocio.
              <br class="hidden md:block" />
              Completas, seguras y pensadas para escalar, sin depender de terceros.
            </p>

            <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4">
              <a
                href="#contacto"
                class="w-full sm:w-auto text-center px-6 py-3 rounded-full bg-gradient-to-r from-indigo-400 to-cyan-400 text-slate-900 text-base sm:text-lg font-medium font-poppins hover:from-indigo-300 hover:to-cyan-300 transition"
              >
                Contanos tu idea
              </a>
              <a
                href="#proyectos"
                class="w-full sm:w-auto text-center px-6 py-3 rounded-full border border-indigo-300/60 text-indigo-100 text-base sm:text-lg font-poppins hover:border-cyan-300 hover:text-cyan-200 transition"
              >
                Ver trabajos
              </a>
            </div>
          </div>
        </section>

        <div class="relative">
          <div class="pointer-events-none hidden md:block absolute inset-y-0 left-8 lg:left-10 w-[2px] bg-indigo-500/30"></div>

          <section id="soluciones" class="py-20 bg-transparent" data-aos="fade-up">
            <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-10 text-left" data-aos="fade-up" data-aos-delay="100">
              <h2 class="font-mont text-3xl md:text-4xl font-semibold mb-10 text-indigo-200">Qué hacemos</h2>
              <div class="grid md:grid-cols-3 gap-8">
                <div class="p-6 border border-white/10 rounded-2xl bg-black/20 hover:border-white/20 hover:bg-black/40 transition-all duration-300" data-aos="fade-up">
                  <h3 class="font-mont text-xl font-semibold mb-2 text-indigo-300">Sitios web modernos</h3>
                  <p class="font-poppins text-neutral-200/80 text-sm leading-relaxed">
                    Creamos páginas web modernas, atractivas y adaptables a cualquier dispositivo. Diseñadas para que tu negocio se vea profesional, sea fácil de encontrar en Google y genere confianza desde el primer vistazo.
                  </p>
                </div>

                <div class="p-6 border border-white/10 rounded-2xl bg-black/20 hover:border-white/20 hover:bg-black/40 transition-all duration-300" data-aos="fade-up">
                  <h3 class="font-mont text-xl font-semibold mb-2 text-indigo-300">Sistemas a medida</h3>
                  <p class="font-poppins text-neutral-200/80 text-sm leading-relaxed">
                    Desarrollamos sistemas internos y paneles de administración hechos a medida, para que puedas gestionar tu negocio de forma simple, rápida y organizada. Todo adaptado exactamente a la forma en que trabajás.
                  </p>
                </div>

                <div class="p-6 border border-white/10 rounded-2xl bg-black/20 hover:border-white/20 hover:bg-black/40 transition-all duration-300" data-aos="fade-up">
                  <h3 class="font-mont text-xl font-semibold mb-2 text-indigo-300">Integraciones y automatización</h3>
                  <p class="font-poppins text-neutral-200/80 text-sm leading-relaxed">
                    Automatizamos tareas repetitivas, como impresión automática de comandas o envío de mensajes a clientes, conectando tu sistema con otras herramientas para que trabajes más rápido y sin errores.
                  </p>
                </div>
              </div>
            </div>
          </section>

          <AboutVideo />
          <PainPoints />
          <BenefitsSection />
          <ReviewSection />
          <Portfolio />
          <ContactSection />
        </div>
      </main>

      <Footer />
    </div>
  </body>

  <script>
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const lowMemoryDevice = typeof navigator.deviceMemory === "number" && navigator.deviceMemory <= 4;

    if (!prefersReducedMotion && !lowMemoryDevice) {
      const { default: AOS } = await import("aos");
      let resizeTimeout;
      const onResize = () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          AOS.refresh();
        }, 200);
      };

      AOS.init({
        duration: 700,
        easing: "ease-out-cubic",
        once: false,
        mirror: true,
        offset: 40,
        throttleDelay: 80,
        debounceDelay: 80,
        disableMutationObserver: true,
        startEvent: "DOMContentLoaded",
      });

      window.addEventListener("resize", onResize, { passive: true });
      window.addEventListener(
        "pagehide",
        () => {
          window.removeEventListener("resize", onResize);
        },
        { once: true }
      );
    }
  </script>
</html>
